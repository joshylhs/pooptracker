rules_version = '2';

// PoopTracker Firestore security rules.
//
// Data is stored plaintext on Firestore. Access control is via these rules.
// Friend-gated reads use a get() on the requester's friendships subcollection
// to check the accepted relationship — costs 1 extra doc read per evaluation.
//
// Deploy: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Any friendship record exists (pending or accepted, requester's side).
    // Used to gate profile reads — recipients of pending requests need to
    // read the requester's profile to display the pending card.
    function knowsUser(otherId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/friendships/$(request.auth.uid)/friends/$(otherId));
    }

    // Accepted friendship — gates summary/heatmap reads. Strict: pending
    // requests do not grant access to log counts.
    function isFriend(otherId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/friendships/$(request.auth.uid)/friends/$(otherId))
        && get(/databases/$(database)/documents/friendships/$(request.auth.uid)/friends/$(otherId)).data.status == 'accepted';
    }

    // User profile (username, avatar, prefs). Plaintext.
    // Self always; anyone in a friendship (pending or accepted) for display.
    match /users/{userId} {
      allow read: if isOwner(userId) || knowsUser(userId);
      allow write: if isOwner(userId);
    }

    // Individual logs — strictly owner-only. Friends never see raw logs.
    match /users/{userId}/logs/{logId} {
      allow read, write: if isOwner(userId);
    }

    // Daily / monthly / yearly summary rollups — readable by accepted friends
    // for leaderboard and heatmap; writable only by owner.
    match /users/{userId}/dailySummaries/{date} {
      allow read: if isOwner(userId) || isFriend(userId);
      allow write: if isOwner(userId);
    }

    match /users/{userId}/monthlyTotals/{month} {
      allow read: if isOwner(userId) || isFriend(userId);
      allow write: if isOwner(userId);
    }

    match /users/{userId}/yearlyTotals/{year} {
      allow read: if isOwner(userId) || isFriend(userId);
      allow write: if isOwner(userId);
    }

    // Username hash index. Lets friend search resolve username → uid via a
    // single doc-id lookup without storing plaintext usernames anywhere.
    match /usernameIndex/{usernameHash} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // Friendships. Cross-user writes are needed for friend requests.
    //
    // Path: friendships/{userId}/friends/{friendId}.
    // "userId" owns the list; "friendId" is the other party.
    match /friendships/{userId}/friends/{friendId} {
      // Owner has full control over their own friend list.
      allow read, write: if isOwner(userId);

      // The other party can read their own entry (e.g. to check whether
      // their outgoing request was accepted).
      allow read: if isSignedIn() && request.auth.uid == friendId;

      // Sending a request: requester (friendId) creates the pending record
      // in the recipient's (userId) list.
      allow create: if isSignedIn()
        && request.auth.uid == friendId
        && request.resource.data.friendId == friendId
        && request.resource.data.initiatedBy == friendId
        && request.resource.data.status == 'pending';

      // Accepting: friendId updates their entry in userId's list to accepted,
      // but only if userId originally initiated the request.
      allow update: if isSignedIn()
        && request.auth.uid == friendId
        && resource.data.initiatedBy == userId
        && request.resource.data.status == 'accepted';

      // Declining or removing: either party can delete the record from the
      // other's list.
      allow delete: if isSignedIn()
        && request.auth.uid == friendId;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
